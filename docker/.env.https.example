# Copy this file to docker/.env.https.local, edit the values, then start with:
# docker compose --env-file docker/.env.https.local -f docker/compose.https.yaml up -d

# Public DNS name or LAN hostname that resolves to the Docker host.
MINDWTR_CLOUD_DOMAIN=mindwtr.myaddr.io

# Use a long random token and paste the same value into Mindwtr settings.
MINDWTR_CLOUD_AUTH_TOKENS=Ss28422842

# Browser/PWA origin allowed by the cloud server. For the Caddy setup, this
# usually matches the public cloud URL.
MINDWTR_CLOUD_CORS_ORIGIN=https://mindwtr.myaddr.io
