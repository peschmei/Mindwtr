# Copy this file to docker/.env.https.local, edit the values, then start with:
# docker compose --env-file docker/.env.https.local -f docker/compose.https.yaml up -d

# Public DNS name or LAN hostname that resolves to the Docker host.
MINDWTR_CLOUD_DOMAIN=mindwtr.example.com

# Use a long random token and paste the same value into Mindwtr settings.
MINDWTR_CLOUD_AUTH_TOKENS=dfg4r5unfghje577i46zfjtusr5z75687

# Browser/PWA origin allowed by the cloud server. For the Caddy setup, this
# usually matches the public cloud URL.
MINDWTR_CLOUD_CORS_ORIGIN=https://mindwtr.example.com

# Leave this on Caddyfile.https for Let's Encrypt/public certificates.
# For LAN-only Caddy internal certificates, change to Caddyfile.local-https.
MINDWTR_CADDYFILE=Caddyfile.https

# Keep 80/443 for automatic public certificates. Change only if another
# service already owns the host ports.
MINDWTR_HTTP_PORT=8011
MINDWTR_HTTPS_PORT=44311
