  "scripts": {
    "desktop:dev": "bun run --filter mindwtr dev",
    "desktop:web": "bun run --filter mindwtr dev:vite",
    "desktop:build": "bun run --filter mindwtr build",
    "desktop:web:build": "bun run --filter mindwtr build:vite",
    "test": "bun run --filter @mindwtr/core test && bun run --filter mindwtr test && bun run --filter mobile test && bun run --filter mindwtr-cloud test",
    "test:perf": "bun run --filter @mindwtr/core test:perf && bun --cwd apps/mobile test tests/large-store-performance.test.tsx",
    "typecheck": "bun run typecheck:desktop && bun run typecheck:mobile",
    "typecheck:desktop": "bunx tsc --noEmit -p apps/desktop/tsconfig.json",
    "typecheck:mobile": "bunx tsc --noEmit -p apps/mobile/tsconfig.json",
    "native:test": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "mobile:start": "bun run --filter mobile start",
    "mobile:android": "bun run --filter mobile android",
    "mobile:ios": "bun run --filter mobile ios",
    "mobile:startup:bench": "bash apps/mobile/scripts/android_startup_benchmark.sh",
    "test:e2e": "playwright test",
    "i18n:check": "bun run scripts/i18n-locale-parity.ts --check",
    "mindwtr:cli": "bun run scripts/mindwtr-cli.ts --",
    "mindwtr:api": "bun run scripts/mindwtr-api.ts --",
    "mindwtr:mcp": "bun run --filter mindwtr-mcp-server dev --",
    "set-version": "bun run scripts/set-version.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
