{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mindwtr",
  "version": "1.1.5",
  "identifier": "tech.dongdongbh.mindwtr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev:vite",
    "beforeBuildCommand": "bun run build:vite"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Mindwtr",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: file:; media-src 'self' asset: http://asset.localhost data: blob: file:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* https:; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "homepage": "https://dongdongbh.tech",
    "targets": [
      "nsis",
      "appimage",
      "deb",
      "rpm",
      "dmg",
      "app"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application",
      "entitlements": "./Entitlements.mac.plist",
      "files": {
        "Info.plist": "./Info.plist"
      }
    },
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^(mailto:[^\\s]+|tel:[^\\s]+|mid:[^\\s]+|https?://[^\\s]+|obsidian://[^\\s]+|ms-windows-store://[^\\s]+)$"
    }
  }
}
